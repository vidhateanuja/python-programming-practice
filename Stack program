#include <stdio.h>
#include <stdlib.h>
#include <conio.h>
#define MAX 10
struct stack {
int items[MAX];
int top;
};
typedef struct stack st;
void createEmptyStaticStack(st *s) {
s->top = -1;
}
int isFull(st *s) {
return (s->top == MAX - 1);
}
int isEmpty(st *s) {

return (s->top == -1);
}
void pushStatic(st *s, int newitem) {
if (isFull(s)) {
printf("Static Stack is FULL\n");
} else {
s->items[++(s->top)] = newitem;
printf("Inserted (Static) -> %d\n", newitem);
}
}
void popStatic(st *s) {
if (isEmpty(s)) {
printf("Static Stack is EMPTY\n");
} else {
printf("Popped (Static) -> %d\n", s->items[s->top--]);
}
}
void peekStatic(st *s) {
if (isEmpty(s)) {
printf("Static Stack is EMPTY\n");
} else {
printf("Top element (Static): %d\n", s->items[s-
>top]);
}

}
void printStatic(st *s) {
if (isEmpty(s)) {
printf("Static Stack is EMPTY\n");
} else {
printf("Static Stack: ");
for (int i = 0; i <= s->top; i++) {
printf("%d ", s->items[i]);
}
printf("\n");
}
}
struct node {
int data;
struct node *next;
};
typedef struct node Node;
Node* pushDynamic(Node *top, int value) {
Node *newNode = (Node*)malloc(sizeof(Node));
newNode->data = value;
newNode->next = top;
printf("Inserted (Dynamic) -> %d\n", value);

return newNode;
}
Node* popDynamic(Node *top) {
if (top == NULL) {
printf("Dynamic Stack is EMPTY\n");
return NULL;
} else {
printf("Popped (Dynamic) -> %d\n", top->data);
Node *temp = top;
top = top->next;
free(temp);
return top;
}
}
void peekDynamic(Node *top) {
if (top == NULL) {
printf("Dynamic Stack is EMPTY\n");
} else {
printf("Top element (Dynamic): %d\n", top->data);
}
}
void printDynamic(Node *top) {
if (top == NULL) {
printf("Dynamic Stack is EMPTY\n");

} else {
Node *temp = top;
printf("Dynamic Stack: ");
while (temp != NULL) {
printf("%d ", temp->data);
temp = temp->next;
}
printf("\n");
}
}
