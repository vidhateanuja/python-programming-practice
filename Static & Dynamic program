#include <stdio.h>
#include <stdlib.h>
#define SIZE 5 // maximum size for static queue
// ---------- Static Queue (Array Implementation) ----------
int queue[SIZE];
int front = -1, rear = -1;
// Function to insert element (Enqueue) in static queue
void enqueue_static(int value) {
if (rear == SIZE - 1)
printf("\n[Static Queue] Queue Overflow!\n");
else {
if (front == -1) front = 0;
rear++;
queue[rear] = value;
printf("[Static Queue] %d inserted.\n", value);
}
}
// Function to delete element (Dequeue) from static queue
void dequeue_static() {
if (front == -1 || front > rear)
printf("\n[Static Queue] Queue Underflow!\n");
else {

printf("[Static Queue] %d deleted.\n", queue[front]);
front++;
}
}
// Function to display static queue
void display_static() {
if (front == -1 || front > rear)
printf("\n[Static Queue] Queue is Empty!\n");
else {
printf("\n[Static Queue Elements]: ");
for (int i = front; i <= rear; i++)
printf("%d ", queue[i]);
printf("\n");
}
}
